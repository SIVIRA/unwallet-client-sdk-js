  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@commitlint/types": "21.0.1",
    "@tsconfig/strictest": "2.0.8",
    "czg": "1.13.1",
    "husky": "9.1.7",
    "publint": "0.3.21",
    "tsdown": "0.22.2"
  },
  "packageManager": "pnpm@11.7.0"
